{
  "name": "resume-builder",
  "version": "0.1.0",
  "description": "AI-assisted JSON Resume pipeline — tailor, render, and score resumes per job ad",
  "main": "dist/pipeline.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "task": "tsx src/pipeline.ts --task",
    "task:1": "tsx src/pipeline.ts --task inputs/tasks/task_1.json",
    "task:2": "tsx src/pipeline.ts --task inputs/tasks/task_2.json"
  },
  "keywords": [
    "resume",
    "json-resume",
    "ats",
    "tailoring",
    "cli",
    "typescript"
  ],
  "author": "Peter Ho",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.6.0",
    "docxtemplater": "^3.68.3",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.2",
    "jsonresume-theme-elegant": "^1.16.1",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pizzip": "^3.2.0",
    "puppeteer": "^24.38.0",
    "resume-cli": "^3.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}